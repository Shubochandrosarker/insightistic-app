# ---------------------------------------------------------------------------
# Insightistic frontend env
# ---------------------------------------------------------------------------
# RECOMMENDED: proxy mode. Leave NEXT_PUBLIC_API_URL empty and the browser will
# call this app's own origin (/api/...), which Next.js forwards to Laravel.
# No CORS, no mixed-content, no "Failed to fetch".
NEXT_PUBLIC_API_URL=

# Where the Next.js server forwards /api/* requests (server-side only).
#   PM2 / single VPS:  http://127.0.0.1:8000
#   Docker compose:    http://api:8000
#   Separate API host: https://api.insightistic.com
API_PROXY_TARGET=http://127.0.0.1:8000

# ---------------------------------------------------------------------------
# ALTERNATIVE: direct mode. Uncomment to make the browser call the API host
# directly (requires CORS, already configured in insightistic-api).
# NEXT_PUBLIC_API_URL=https://api.insightistic.com
