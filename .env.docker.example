HTTP_PORT=80

APP_URL=https://api.insightistic.com
INSIGHTISTIC_APP_URL=https://app.insightistic.com

# Frontend API connection (proxy mode by default). Leave NEXT_PUBLIC_API_URL
# EMPTY so the browser calls the app's own origin and Next.js forwards /api/*
# to the API container — no CORS, no mixed-content, no "Failed to fetch".
NEXT_PUBLIC_API_URL=
API_PROXY_TARGET=http://api:8000

# Lock CORS down for direct mode (optional in proxy mode). Comma-separated.
CORS_ALLOWED_ORIGINS=https://app.insightistic.com,https://insightistic.com

# ---- Social login (optional) ----------------------------------------------
# Create OAuth apps and paste credentials here to enable the buttons.
# Default callback (proxy mode):  https://app.insightistic.com/api/auth/oauth/<provider>/callback
# OAUTH_REDIRECT_BASE=https://app.insightistic.com
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=
MICROSOFT_TENANT=common
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# Generate one with: php artisan key:generate --show
APP_KEY=base64:CHANGE_ME_GENERATE_WITH_ARTISAN_KEY_GENERATE

DB_DATABASE=insightistic
DB_USERNAME=insightistic
DB_PASSWORD=change-this-db-password

INSIGHTISTIC_AI_PROVIDER=openai
INSIGHTISTIC_AI_MODEL=gpt-4o-mini
OPENAI_API_KEY=

MAIL_MAILER=smtp
MAIL_HOST=
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS=reports@insightistic.com
MAIL_FROM_NAME=Insightistic

STRIPE_SECRET=
STRIPE_WEBHOOK_SECRET=

RUN_MIGRATIONS=true
SEED_PLANS=true
