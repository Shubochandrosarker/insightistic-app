HTTP_PORT=80

APP_URL=https://api.insightistic.com
INSIGHTISTIC_APP_URL=https://app.insightistic.com
NEXT_PUBLIC_API_URL=https://api.insightistic.com

# Generate one with: php artisan key:generate --show
APP_KEY=base64:CHANGE_ME_GENERATE_WITH_ARTISAN_KEY_GENERATE

DB_DATABASE=insightistic
DB_USERNAME=insightistic
DB_PASSWORD=change-this-db-password

INSIGHTISTIC_AI_PROVIDER=openai
INSIGHTISTIC_AI_MODEL=gpt-4o-mini
OPENAI_API_KEY=

MAIL_MAILER=smtp
MAIL_HOST=
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS=reports@insightistic.com
MAIL_FROM_NAME=Insightistic

STRIPE_SECRET=
STRIPE_WEBHOOK_SECRET=

RUN_MIGRATIONS=true
SEED_PLANS=true
